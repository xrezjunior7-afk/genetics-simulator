  "tutorials": {
    "monohybrid": {
      "title": "Hukum Mendel I (Segregasi)",
      "description": "Hukum segregasi menyatakan bahwa setiap individu memiliki sepasang alel untuk setiap sifat, dan alel-alel ini memisah (segregasi) selama pembentukan gamet.",
      "steps": [
        "Pilih organisme yang ingin dipelajari",
        "Pilih satu sifat (trait) yang akan disilangkan",
        "Tentukan alel dominan dan resesif",
        "Pilih fenotipe parent 1 dan parent 2",
        "Amati hasil persilangan pada tabel Punnett",
        "Analisis rasio genotipe dan fenotipe hasil keturunan"
      ]
    },
    "dihybrid": {
      "title": "Hukum Mendel II (Pengelompokan Bebas)",
      "description": "Hukum pengelompokan bebas menyatakan bahwa alel dari gen yang berbeda akan diwariskan secara independen satu sama lain selama pembentukan gamet.",
      "steps": [
        "Pilih organisme yang ingin dipelajari",
        "Pilih dua sifat (traits) yang akan disilangkan",
        "Tentukan alel dominan dan resesif untuk setiap sifat",
        "Pilih fenotipe kedua parent untuk kedua sifat",
        "Amati hasil persilangan pada tabel Punnett 4x4",
        "Analisis rasio fenotipe hasil keturunan (9:3:3:1)"
      ]
    }
  },
